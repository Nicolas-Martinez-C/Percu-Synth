void computeHPF(float freq, float Q) {
  float w = 2.0f * (float)M_PI * freq / SAMPLE_RATE;
  float c = cosf(w), s = sinf(w);
  float a = s / (2.0f * Q);
  float n = 1.0f / (1.0f + a);
  hpf_b0 =  (1.0f + c) * 0.5f * n;
  hpf_b1 = -(1.0f + c) * n;
  hpf_b2 =  hpf_b0;
  hpf_a1 = -2.0f * c * n;
  hpf_a2 =  (1.0f - a) * n;
}

inline float applyHPF(float x) {
  float y = hpf_b0*x + hpf_b1*hpf_x1 + hpf_b2*hpf_x2
              - hpf_a1*hpf_y1 - hpf_a2*hpf_y2;
  hpf_x2=hpf_x1; hpf_x1=x; hpf_y2=hpf_y1; hpf_y1=y;
  return y;
}

void computeLPF(float freq, float Q) {
  float w = 2.0f * (float)M_PI * freq / SAMPLE_RATE;
  float c = cosf(w), s = sinf(w);
  float a = s / (2.0f * Q);
  float n = 1.0f / (1.0f + a);
  lpf_b0 = (1.0f - c) * 0.5f * n;
  lpf_b1 = (1.0f - c) * n;
  lpf_b2 = lpf_b0;
  lpf_a1 = -2.0f * c * n;
  lpf_a2 = (1.0f - a) * n;
}

inline float applyLPF(float x) {
  float y = lpf_b0*x + lpf_b1*lpf_x1 + lpf_b2*lpf_x2
              - lpf_a1*lpf_y1 - lpf_a2*lpf_y2;
  lpf_x2=lpf_x1; lpf_x1=x; lpf_y2=lpf_y1; lpf_y1=y;
  return y;
}

// Soft limiter: transparente hasta 0.85, saturación suave hasta 1.0
inline float softLimit(float x) {
  const float knee = 0.85f;
  float a = fabsf(x);
  if (a <= knee) return x;
  float s = (x < 0.0f) ? -1.0f : 1.0f;
  return s * (knee + (1.0f - knee) * tanhf((a - knee) / (1.0f - knee)));
}

// ================================================================
// I2S (PCM5102)
// ================================================================
i2s_chan_handle_t tx_handle;

void initI2S() {
  i2s_chan_config_t cc = I2S_CHANNEL_DEFAULT_CONFIG(I2S_NUM_0, I2S_ROLE_MASTER);
  i2s_new_channel(&cc, &tx_handle, NULL);
  i2s_std_config_t sc = {
    .clk_cfg  = I2S_STD_CLK_DEFAULT_CONFIG(SAMPLE_RATE),
    .slot_cfg = I2S_STD_PHILIPS_SLOT_DEFAULT_CONFIG(
                  I2S_DATA_BIT_WIDTH_16BIT, I2S_SLOT_MODE_STEREO),
    .gpio_cfg = {
      .mclk = I2S_GPIO_UNUSED,
      .bclk = (gpio_num_t)PIN_I2S_BCK,
      .ws   = (gpio_num_t)PIN_I2S_LRCK,
      .dout = (gpio_num_t)PIN_I2S_DIN,
      .din  = I2S_GPIO_UNUSED
    }
  };
  i2s_channel_init_std_mode(tx_handle, &sc);
  i2s_channel_enable(tx_handle);
}

// ================================================================
// HELPERS
// ================================================================
int readPot(uint8_t pin) {
  int s = 0;
  for (int i = 0; i < 8; i++) s += analogRead(pin);
  return s >> 3;
}

// Dispara una voz de hit con voice stealing si no hay voces libres
float g_pitchRatio = 1.0f;

void triggerHit(int sampleIdx, float velocity) {
  if (HIT_LENS[sampleIdx] == 0) return;
  int voice = -1;
  for (int i = 0; i < NUM_HIT_VOICES; i++) {
    if (!hit_v[i].active) { voice = i; break; }
  }
  if (voice < 0) {
    // Roba la voz más avanzada (mayor pos/length)
    float mx = -1.0f;
    for (int i = 0; i < NUM_HIT_VOICES; i++) {
      float prog = hit_v[i].pos / (float)hit_v[i].length;
      if (prog > mx) { mx = prog; voice = i; }
    }
  }
  hit_v[voice].data       = HIT_DATA[sampleIdx];
  hit_v[voice].length     = HIT_LENS[sampleIdx];
  hit_v[voice].pos        = 0.0f;
  hit_v[voice].pitchRatio = g_pitchRatio;
  hit_v[voice].velocity   = velocity;
  hit_v[voice].active     = true;
}

// Lee aceleración del MPU6050 — retorno rápido si falla I2C
void readAccel(float &ax, float &ay) {
  Wire.beginTransmission(MPU6050_ADDR);
  Wire.write(0x3B);
  if (Wire.endTransmission(false) != 0) return;
  if (Wire.requestFrom((uint8_t)MPU6050_ADDR, (uint8_t)4) < 4) return;
  int16_t ax16 = ((int16_t)Wire.read() << 8) | (uint8_t)Wire.read();
  int16_t ay16 = ((int16_t)Wire.read() << 8) | (uint8_t)Wire.read();
  ax = ax16 / 16384.0f;
  ay = ay16 / 16384.0f;
}

// ================================================================
// SETUP
// ================================================================
bool     btnPrev[5]        = {};
uint32_t btnLastMs[5]      = {};
uint32_t piezoLastMs[4]    = {};
bool     imuOK             = false;
#define  DEBOUNCE_MS  50
#define  PIEZO_DEBOUNCE_MS 60

void setup() {
  Serial.begin(115200);
  Serial.println("PercuSynth Loop Player — iniciando...");
  analogReadResolution(12);

  for (int i = 0; i < 5; i++) pinMode(BTN_PINS[i], INPUT_PULLUP);

  // MPU6050 — detectar antes de usar
  Wire.begin(PIN_I2C_SDA, PIN_I2C_SCL);
  Wire.setClock(400000);
  Wire.beginTransmission(MPU6050_ADDR);
  Wire.write(0x6B);
  Wire.write(0x00);
  imuOK = (Wire.endTransmission() == 0);
  if (imuOK) {
    Wire.beginTransmission(MPU6050_ADDR);
    Wire.write(0x1C);
    Wire.write(0x00);
    Wire.endTransmission();
    Serial.println("IMU: MPU6050 OK");
  } else {
    Serial.println("IMU: MPU6050 no encontrado — LPF fijo 10kHz");
  }

  // Voces
  for (int i = 0; i < NUM_LOOPS; i++)     loop_v[i].active = false;
  for (int i = 0; i < NUM_HIT_VOICES; i++) hit_v[i].active  = false;

  initI2S();
  computeLPF(10000.0f, 0.707f);
  computeHPF(20.0f,    0.707f);

  Serial.println("Listo.");
  for (int i = 0; i < NUM_LOOPS; i++)
    Serial.printf("  Loop %d: %u samples (%.3fs)\n", i, LOOP_LENS[i], LOOP_LENS[i]/(float)SAMPLE_RATE);
  for (int i = 0; i < NUM_HITS; i++)
    Serial.printf("  Hit  %d: %u samples (%.3fs)\n", i, HIT_LENS[i], HIT_LENS[i]/(float)SAMPLE_RATE);
  Serial.println("Pots: ADC1=pitch ADC2=HPF ADC8=piezoSens ADC10=vol");
}

// ================================================================
// LOOP
// ================================================================
void loop() {
  uint32_t now = millis();

  // --- Leer pots ---
  float potPitch = readPot(POT_PINS[0]) / 4095.0f;  // 0..1
  float potHPF   = readPot(POT_PINS[1]) / 4095.0f;
  float potSens  = readPot(POT_PINS[2]) / 4095.0f;  // sensibilidad piezo
  // Volumen: rango 0.1–1.0 (nunca cero para evitar silencio total con pot a cero)
  float potVol   = 0.1f + readPot(POT_PINS[3]) / 4095.0f * 0.9f;

  // Pitch: centro(0.5)=1.0x, izq=0.5x (octava abajo), der=2.0x (octava arriba)
  g_pitchRatio = powf(2.0f, (potPitch - 0.5f) * 2.0f);

  // HPF: pot^2 para respuesta musical, rango 20–4000 Hz
  float hpfFreq = 20.0f + potHPF * potHPF * 3980.0f;
  computeHPF(hpfFreq, 0.707f);

  // --- Leer IMU cada 10ms solo si fue detectado en setup ---
  static uint32_t imuLastMs = 0;
  static float ax = 0.5f, ay = 0.0f;  // defaults → LPF 10kHz, Q 5
  if (imuOK && now - imuLastMs >= 10) {
    imuLastMs = now;
    readAccel(ax, ay);
  }
  // ax ∈ [-1,+1]g → LPF freq 200–20000 Hz
  float lpfFreq = 200.0f + ((ax + 1.0f) * 0.5f) * 19800.0f;
  lpfFreq = constrain(lpfFreq, 200.0f, 20000.0f);
  // ay ∈ [-1,+1]g → Q 0.5–10.0
  float lpfQ = 0.5f + ((ay + 1.0f) * 0.5f) * 9.5f;
  lpfQ = constrain(lpfQ, 0.5f, 10.0f);
  computeLPF(lpfFreq, lpfQ);

  // --- Botones loops (0,1,2) — toggle ---
  for (int i = 0; i < 3; i++) {
    bool pressed = (digitalRead(BTN_PINS[i]) == LOW);
    if (pressed && !btnPrev[i] && now - btnLastMs[i] > DEBOUNCE_MS) {
      btnLastMs[i] = now;
      if (loop_v[i].active) {
        loop_v[i].active = false;
        Serial.printf("Loop %d OFF\n", i);
      } else if (LOOP_LENS[i] > 0) {
        loop_v[i].data   = LOOP_DATA[i];
        loop_v[i].length = LOOP_LENS[i];
        loop_v[i].pos    = 0.0f;
        loop_v[i].active = true;
        Serial.printf("Loop %d ON  len=%u\n", i, LOOP_LENS[i]);
      }
    }
    btnPrev[i] = pressed;
  }

  // --- Botones hits (3,4) → hit 0,1 ---
  for (int i = 3; i < 5; i++) {
    bool pressed = (digitalRead(BTN_PINS[i]) == LOW);
    if (pressed && !btnPrev[i] && now - btnLastMs[i] > DEBOUNCE_MS) {
      btnLastMs[i] = now;
      triggerHit(i - 3, 1.0f);
      Serial.printf("Hit %d  pitch=%.3f\n", i-3, g_pitchRatio);
    }
    btnPrev[i] = pressed;
  }

  // --- Piezos → hits 2-5 ---
  // Umbral: potSens mapea [0,1] → [200, 2500] (ADC 12-bit)
  int piezoThreshold = (int)(200 + potSens * 2300);
  for (int p = 0; p < 4; p++) {
    int val = analogRead(PIEZO_PINS[p]);
    if (val > piezoThreshold && now - piezoLastMs[p] > PIEZO_DEBOUNCE_MS) {
      piezoLastMs[p] = now;
      float vel = constrain((float)(val - piezoThreshold) / (float)(4095 - piezoThreshold), 0.2f, 1.0f);
      triggerHit(p + 2, vel);
      Serial.printf("Piezo %d  val=%d vel=%.2f\n", p, val, vel);
    }
  }

  // --- Llenar buffer de audio ---
  static int16_t buf[BUF_SAMPLES * 2];

  for (int s = 0; s < BUF_SAMPLES; s++) {
    float loopMix = 0.0f;
    float hitMix  = 0.0f;

    // Loops (pitch siempre 1.0 para mantener sincronía)
    for (int i = 0; i < NUM_LOOPS; i++) {
      if (!loop_v[i].active) continue;
      uint32_t pos  = (uint32_t)loop_v[i].pos;
      float    frac = loop_v[i].pos - (float)pos;
      float    s0   = (float)loop_v[i].data[pos];
      // s1 wrappea al inicio si pos es el último sample
      float    s1   = (float)loop_v[i].data[(pos + 1 < loop_v[i].length) ? pos + 1 : 0];
      loopMix += s0 + frac * (s1 - s0);
      loop_v[i].pos += 1.0f;
      if (loop_v[i].pos >= (float)loop_v[i].length)
        loop_v[i].pos -= (float)loop_v[i].length;
    }

    // Hits (con pitch y velocity)
    for (int i = 0; i < NUM_HIT_VOICES; i++) {
      if (!hit_v[i].active) continue;
      uint32_t pos  = (uint32_t)hit_v[i].pos;
      float    frac = hit_v[i].pos - (float)pos;
      float    s0   = (float)hit_v[i].data[pos];
      float    s1   = (pos + 1 < hit_v[i].length) ? (float)hit_v[i].data[pos+1] : 0.0f;
      hitMix += (s0 + frac*(s1-s0)) * hit_v[i].velocity;
      hit_v[i].pos += hit_v[i].pitchRatio;
      if ((uint32_t)hit_v[i].pos >= hit_v[i].length) hit_v[i].active = false;
    }

    // Mezclar: loop@45% + hits@33% cada uno → max ~0.45+0.99=1.44 antes del softLimit
    float mix = (loopMix * 0.45f + hitMix * 0.33f) / 32768.0f;

    // Volumen master
    mix *= potVol;

    // Cadena de filtros: HPF (pot) → LPF (IMU)
    mix = applyHPF(mix);
    mix = applyLPF(mix);

    // Soft limiter — no hay clipping duro
    mix = softLimit(mix);

    int16_t out = (int16_t)(mix * 32767.0f);
    buf[s*2]   = out;  // L
    buf[s*2+1] = out;  // R
  }

  size_t written;
  i2s_channel_write(tx_handle, buf, sizeof(buf), &written, portMAX_DELAY);
}