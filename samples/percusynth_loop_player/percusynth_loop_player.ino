// FILTROS BIQUAD — HPF (pot) + LPF (IMU)
// ================================================================
static float hpf_x1=0,hpf_x2=0,hpf_y1=0,hpf_y2=0;
static float hpf_b0=1,hpf_b1=0,hpf_b2=0,hpf_a1=0,hpf_a2=0;
