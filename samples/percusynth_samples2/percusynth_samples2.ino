float bq_b0 = 1, bq_b1, bq_b2, bq_a1, bq_a2;

void computeLPF(float cutoff, float reso) {
  float omega  = 2.0f * (float)M_PI * cutoff / SAMPLE_RATE;
  float cosW   = cosf(omega);
  float sinW   = sinf(omega);
  float Q      = 0.5f + reso * 9.5f;
  float alpha  = sinW / (2.0f * Q);
  float a0inv  = 1.0f / (1.0f + alpha);
  bq_b0 = (1.0f - cosW) * 0.5f * a0inv;
  bq_b1 = (1.0f - cosW) * a0inv;
  bq_b2 = bq_b0;
  bq_a1 = -2.0f * cosW * a0inv;
  bq_a2 = (1.0f - alpha) * a0inv;
}

inline float applyLPF(float x) {
  float y = bq_b0*x + bq_b1*bq_x1 + bq_b2*bq_x2 - bq_a1*bq_y1 - bq_a2*bq_y2;
  bq_x2 = bq_x1; bq_x1 = x;
  bq_y2 = bq_y1; bq_y1 = y;
  return y;
}

// =======================================================
// TREMOLO (PWM pot)
// =======================================================
float pwmPhase = 0.0f;

inline float applyTremolo(float s, float rateHz, float depth) {
  pwmPhase += rateHz / (float)SAMPLE_RATE;
  if (pwmPhase >= 1.0f) pwmPhase -= 1.0f;
  return s * (1.0f - depth * 0.5f * (1.0f - cosf(2.0f * (float)M_PI * pwmPhase)));
}

// =======================================================
// I2S (PCM5102)
// =======================================================
i2s_chan_handle_t tx_handle;

void initI2S() {
  i2s_chan_config_t cc = I2S_CHANNEL_DEFAULT_CONFIG(I2S_NUM_0, I2S_ROLE_MASTER);
  i2s_new_channel(&cc, &tx_handle, NULL);
  i2s_std_config_t sc = {
    .clk_cfg  = I2S_STD_CLK_DEFAULT_CONFIG(SAMPLE_RATE),
    .slot_cfg = I2S_STD_PHILIPS_SLOT_DEFAULT_CONFIG(
                  I2S_DATA_BIT_WIDTH_16BIT, I2S_SLOT_MODE_STEREO),
    .gpio_cfg = {
      .mclk = I2S_GPIO_UNUSED,
      .bclk = (gpio_num_t)PIN_I2S_BCK,
      .ws   = (gpio_num_t)PIN_I2S_LRCK,
      .dout = (gpio_num_t)PIN_I2S_DIN,
      .din  = I2S_GPIO_UNUSED
    }
  };
  i2s_channel_init_std_mode(tx_handle, &sc);
  i2s_channel_enable(tx_handle);
}

// =======================================================
// HELPERS
// =======================================================
int readPot(uint8_t pin) {
  int s = 0;
  for (int i = 0; i < 8; i++) s += analogRead(pin);
  return s >> 3;
}

float phrygianRatio(float norm) {
  int idx = (int)(norm * (PHRYGIAN_LEN - 1) + 0.5f);
  if (idx < 0) idx = 0;
  if (idx >= PHRYGIAN_LEN) idx = PHRYGIAN_LEN - 1;
  return powf(2.0f, (float)PHRYGIAN_NOTES[idx] / 12.0f);
}

// Monophonic: stop all other voices before triggering a new one
void triggerVoice(int i) {
  for (int j = 0; j < NUM_VOICES; j++) voices[j].active = false;
  voices[i].data       = SAMPLES[i];
  voices[i].length     = SAMPLE_LENS[i];
  voices[i].position   = 0.0f;
  voices[i].pitchRatio = samplePitch[i];
  voices[i].active     = (SAMPLE_LENS[i] > 0);
}

// =======================================================
// SETUP
// =======================================================
bool     btnPrev[NUM_VOICES]      = {};
uint32_t lastTrigger[NUM_VOICES]  = {};
#define  DEBOUNCE_MS 50

void setup() {
  Serial.begin(115200);
  Serial.println("PercuSynth Sample Firmware");
  analogReadResolution(12);
  for (int i = 0; i < NUM_VOICES; i++) {
    pinMode(BTN_PINS[i], INPUT_PULLUP);
    voices[i].active = false;
  }
  initI2S();
  computeLPF(8000.0f, 0.0f);
  Serial.println("Ready.");
  Serial.println("Buttons: GPIO 44,42,0,45,47");
  Serial.println("Pots: GPIO 1=pitch  2=filter  8=reso  10=pwm");
}

// =======================================================
// LOOP
// =======================================================
void loop() {
  // Pots
  float potPitch  = readPot(POT_PINS[0]) / 4095.0f;
  float potFilter = readPot(POT_PINS[1]) / 4095.0f;
  float potReso   = readPot(POT_PINS[2]) / 4095.0f;
  float potPWM    = readPot(POT_PINS[3]) / 4095.0f;

  // Buttons
  for (int i = 0; i < NUM_VOICES; i++) {
    bool pressed = (digitalRead(BTN_PINS[i]) == LOW);
    if (pressed && !btnPrev[i] && millis() - lastTrigger[i] > DEBOUNCE_MS) {
      triggerVoice(i);
      lastTrigger[i] = millis();
      Serial.printf("Voice %d triggered  pitch=%.4f\n", i, samplePitch[i]);
    }
    if (pressed) {
      // Hold button + pitch pot → assign Phrygian pitch to this sample only
      float p = phrygianRatio(potPitch);
      samplePitch[i]       = p;   // saved for next trigger
      voices[i].pitchRatio = p;   // applied live to current playback
    }
    btnPrev[i] = pressed;
  }

  // Filter (pot² curve for musical response)
  float cutoff = 200.0f + potFilter * potFilter * 19800.0f;
  computeLPF(cutoff, potReso);

  // Audio buffer
  static int16_t buf[BUF_SAMPLES * 2];
  for (int s = 0; s < BUF_SAMPLES; s++) {
    float mix = 0.0f;
    for (int i = 0; i < NUM_VOICES; i++) {
      if (!voices[i].active) continue;
      uint32_t pos  = (uint32_t)voices[i].position;
      float    frac = voices[i].position - (float)pos;
      float    s0   = (float)voices[i].data[pos];
      float    s1   = (pos + 1 < voices[i].length) ? (float)voices[i].data[pos + 1] : 0.0f;
      mix += s0 + frac * (s1 - s0);  // linear interpolation
      voices[i].position += voices[i].pitchRatio;
      if ((uint32_t)voices[i].position >= voices[i].length) voices[i].active = false;
    }
    mix /= 32768.0f;                                     // normalize
    mix  = applyLPF(mix);                                // filter
    float treRate  = 0.5f + potPWM * 19.5f;             // 0.5–20 Hz
    float treDepth = potPWM * 0.9f;
    mix  = applyTremolo(mix, treRate, treDepth);         // tremolo/PWM
    int32_t out = (int32_t)(mix * 32767.0f);
    if (out >  32767) out =  32767;
    if (out < -32768) out = -32768;
    buf[s*2]     = (int16_t)out;   // L
    buf[s*2 + 1] = (int16_t)out;   // R
  }

  size_t written;
  i2s_channel_write(tx_handle, buf, sizeof(buf), &written, portMAX_DELAY);
}