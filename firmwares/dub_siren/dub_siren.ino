// ================================================================

// Lectura de UN sample (cualquiera de los 3) con interpolación lineal.
// buf+len permiten pasar SAMPLE_1, SAMPLE_2 o SAMPLE_3 al vuelo.
static inline float readSampleAt(const int16_t *buf, uint32_t len, double pos) {
  if (len < 2) return 0.0f;
  uint32_t i0 = (uint32_t)pos;
  if (i0 >= len) i0 = len - 1;
  uint32_t i1 = (i0 + 1 < len) ? (i0 + 1) : 0;
  float frac = (float)(pos - (double)i0);
  float s0   = (float)buf[i0];
  float s1   = (float)buf[i1];
  return s0 + frac * (s1 - s0);
}

// Soft-clip cúbico para el OUTPUT final · agrega un poquito de armónicos
// musicales en señales fuertes. Se aplica UNA sola vez por sample → ok.
static inline int16_t softClip(float x) {
  float xn = x * (1.0f / 32768.0f);
  if (xn >  1.5f) xn =  1.5f;
  if (xn < -1.5f) xn = -1.5f;
  float y = xn - (xn * xn * xn) * 0.3333333f;
  int32_t out = (int32_t)(y * 36044.0f);
  if (out >  32767) out =  32767;
  if (out < -32768) out = -32768;
  return (int16_t)out;
}

// Saturador racional: y = x / (1 + |x|/k) · transparente para niveles
// bajos, asintótico a ±k. NO genera los armónicos acumulativos del cúbico —
// crucial para señales que recirculan en el feedback del delay.
static inline int16_t softSaturate(float x) {
  const float k = 30000.0f;
  float ax = fabsf(x);
  float y  = x / (1.0f + ax * (1.0f / k));
  int32_t out = (int32_t)y;
  if (out >  32767) out =  32767;
  if (out < -32768) out = -32768;
  return (int16_t)out;
}

// Dispara el osc siren: env=1, fase a cero (clic mínimo).
static inline void sirenTrigger(float freq) {
  osc.freq  = freq;
  osc.phase = 0.0f;
  osc.env   = 1.0f;
}

// Genera una muestra del osc según su forma de onda.
static inline float sirenSample(float phase, SirenWave w) {
  switch (w) {
    case WAVE_SINE:   return sinf(phase * 6.2831853f);
    case WAVE_SQUARE: return (phase < 0.5f) ? 1.0f : -1.0f;
    case WAVE_SAW:    return phase * 2.0f - 1.0f;
  }
  return 0.0f;
}

// ================================================================
// RENDER — pipeline:
//   [Sample 1] ─┐
//   [Sample 2] ─┼─→ Σ → [Delay tape c/feedback] → softClip → I2S
//   [Sample 3] ─┤
//   [Siren]    ─┘
//   IMU eje X → global_pitch (afecta los 3 samples y siren freq).
//   LFO modula global_pitch (±6%) y siren freq (±25%).
// ================================================================
static void renderBlock() {
  const float  lfo_inc     = lfo.rate * INV_I2S_SR;
  const float  sample_mod  = lfo.depth * 0.50f;   // ±50% wobble dramático en samples
  const float  siren_mod   = lfo.depth * 0.50f;   // ±50% siren freq swing

  // Target delay en samples (mínimo 1 para evitar comb instantáneo)
  float target_delay = dly.time * (float)(DELAY_SAMPLES - 1);
  if (target_delay < 1.0f) target_delay = 1.0f;

  // SLEW rate del current_delay hacia target. Más bajo = pitch sweep más largo
  // y dramático al mover POT3; más alto = settling más rápido. 0.0003 ≈ 50 ms
  // para llegar al 50% del target — el sweet spot de un tape echo clásico.
  const float TAPE_SLEW = 0.0003f;

  // Snapshot del pitch global modulado — se aplica a las 3 voces y al siren.
  const float global_pitch = global_pitch_smoothed;

  for (uint32_t i = 0; i < BUF_SAMPLES; i++) {
    // ---- LFO ----
    lfo.phase += lfo_inc;
    if (lfo.phase >= 1.0f) lfo.phase -= 1.0f;
    float lfo_val = sinf(lfo.phase * 6.2831853f);

    // ---- 3 voces de sample sumadas (pitch unificado por IMU + LFO) ----
    float sample_out = 0.0f;
    float pitch_eff  = global_pitch * (1.0f + sample_mod * lfo_val);
    double phase_inc = (double)pitch_eff * SR_RATIO;
    for (int v = 0; v < 3; v++) {
      if (!sp[v].playing) continue;
      sp[v].phase += phase_inc;
      while (sp[v].phase >= (double)sp[v].len) sp[v].phase -= (double)sp[v].len;
      while (sp[v].phase <  0.0)               sp[v].phase += (double)sp[v].len;
      // Cada voz aporta 30% para que la suma de 3 voces + siren tenga headroom.
      sample_out += readSampleAt(sp[v].buf, sp[v].len, sp[v].phase) * 0.30f;
    }

    // ---- Siren osc (gate sostiene, release inicia decay) ----
    float siren_out = 0.0f;
    if (osc.gate) {
      osc.env = 1.0f;       // sustain mientras BTN4 está hold
    } else {
      osc.env *= env_decay_per_sample;   // decay al soltar
      if (osc.env < 0.0001f) osc.env = 0.0f;
    }
    if (osc.env > 0.0001f) {
      float freq_eff = osc.freq * (1.0f + siren_mod * lfo_val);
      osc.phase += freq_eff * INV_I2S_SR;
      if (osc.phase >= 1.0f) osc.phase -= 1.0f;
      if (osc.phase <  0.0f) osc.phase += 1.0f;
      siren_out = sirenSample(osc.phase, osc.wave) * osc.env * 9000.0f;
    }

    // ---- Mix sample + siren (full level para el dry del output) ----
    float pre = sample_out + siren_out;

    // ---- Delay tape ----
    // El INPUT al delay va atenuado para dar headroom: cuando recircula con
    // feedback alto, no acumula saturación. El dry sigue saliendo full level
    // por el mix de abajo — esto solo afecta lo que se feedbackea.
    const float DELAY_INPUT_GAIN = 0.5f;

    // Slew del delay actual hacia el target → efecto cinta.
    // El read avanza a (write_speed - d(current_delay)/dn) por output sample.
    // Cuando current_delay crece (target_delay subió, e.g. POT3 hacia arriba),
    // el read avanza < 1 sample/sample → pitch BAJA (cinta frenando).
    // Cuando decrece → pitch SUBE (cinta acelerando).
    dly.current_delay += TAPE_SLEW * (target_delay - dly.current_delay);

    // Read fraccional con interpolación lineal
    float read_phase = (float)dly.write_pos - dly.current_delay;
    while (read_phase <  0.0f)                  read_phase += (float)DELAY_SAMPLES;
    while (read_phase >= (float)DELAY_SAMPLES)  read_phase -= (float)DELAY_SAMPLES;
    uint32_t r0   = (uint32_t)read_phase;
    uint32_t r1   = (r0 + 1) % DELAY_SAMPLES;
    float    rfr  = read_phase - (float)r0;
    float    delayed = (float)dly.buf[r0] + rfr * ((float)dly.buf[r1] - (float)dly.buf[r0]);

    float to_write = pre * DELAY_INPUT_GAIN + delayed * dly.feedback;
    // softSaturate (racional) en vez de softClip (cúbico) — no acumula armónicos
    // al recircular. Esto es lo que vuelve limpias las repeticiones.
    dly.buf[dly.write_pos] = softSaturate(to_write);
    dly.write_pos = (dly.write_pos + 1) % DELAY_SAMPLES;

    // ---- Mix dry + wet (el dry pasa entero, el wet escalado a equilibrar) ----
    // El wet se sube ×1.6 para compensar el DELAY_INPUT_GAIN y que las
    // repeticiones se oigan al mismo nivel que el dry original.
    float mix = pre * 0.55f + delayed * 0.9f;

    // softClip cúbico solo en el output final · agrega calor pero NO recircula
    int16_t s = softClip(mix);
    out_buf[i * 2]     = s;
    out_buf[i * 2 + 1] = s;
  }
}

// ================================================================
// SETUP
// ================================================================
void setup() {
  Serial.begin(115200);
  uint32_t t = millis();
  while (!Serial && millis() - t < 2000) delay(10);

  Serial.println();
  Serial.println("================================================");
  Serial.println(" dub_siren v0.6  ·  PercuSynth · 3 samples");
  Serial.println("================================================");
  for (int i = 0; i < 3; i++) {
    Serial.printf(" Sample %d: %u samples (%.3fs)\n",
                  i+1, SAMPLE_LENS[i], (float)SAMPLE_LENS[i] / (float)SAMPLE_SR);
  }
  Serial.printf(" SR ratio (sample→I2S): %.3f\n", SR_RATIO);
  Serial.println(" POTs: POT1=lfoDepth  POT2=lfoRate  POT3=dlyTime  POT4=dlyFb");
  Serial.println(" IMU:  eje X → pitch global (0.25× a 4×)");
  Serial.println(" BTNs: 1=sample1 HOLD · 2=sample2 HOLD · 3=sample3 HOLD");
  Serial.println("       4=siren HOLD    · 5=random sample HOLD");
  Serial.println();

  analogReadResolution(12);
  buttonsInit();
  i2sSetup();

  // I2C + MPU6050
  Wire.begin(IMU_SDA, IMU_SCL);
  mpu.initialize();
  imu_ok = mpu.testConnection();
  Serial.printf(" IMU MPU6050: %s\n", imu_ok ? "OK" : "NO RESPONDE (pitch global = 1.0×)");

  // LED on-board RGB · estado de transporte
  FastLED.addLeds<WS2812, PIN_ONBOARD_LED, GRB>(onboard_led, 1);
  FastLED.setBrightness(LED_BRIGHTNESS);
  updateTransportLed();   // arranca apagado (TRANSPORT_STOP)

  // Init de las 3 voces — cada una apunta a su sample correspondiente
  for (int i = 0; i < 3; i++) {
    sp[i].buf     = SAMPLE_DATA[i];
    sp[i].len     = SAMPLE_LENS[i];
    sp[i].phase   = 0.0;
    sp[i].playing = false;
  }

  // Init del delay buffer (zero) y posición de escritura
  for (uint32_t i = 0; i < DELAY_SAMPLES; i++) dly.buf[i] = 0;
  dly.write_pos     = 0;
  dly.time          = 0.3f;
  dly.feedback      = 0.55f;
  dly.current_delay = dly.time * (float)(DELAY_SAMPLES - 1);

  // Coeficiente de decay exponencial del env del siren
  env_decay_per_sample =
    expf(-1.0f / ((float)SIREN_DECAY_MS * 0.001f * (float)I2S_SR));

  Serial.println("Listo. Dale fuego.");
}

// ================================================================
// LOOP
// ================================================================
void loop() {
  buttonsUpdate();
  uint32_t now = millis();

  // ---- Pots SMOOTHED: POT1 lfoDepth · POT2 lfoRate · POT3 dlyTime · POT4 dlyFb ----
  float n1 = readPotSmooth(0);
  float n2 = readPotSmooth(1);
  float n3 = readPotSmooth(2);
  float n4 = readPotSmooth(3);

  lfo.depth    = n1;                                  // 0 – 100% (POT1)
  lfo.rate     = 0.1f  * powf(200.0f, n2);           // 0.1 – 20 Hz exp
  dly.time     = 0.01f + n3 * n3 * 0.99f;            // 1% – 100% (x²)
  dly.feedback = n4 * 1.0f;                           // 0 – 100%

  // ---- IMU → pitch global (gestual, eje X) ----
  // ax/16384 da -1 a +1 g · mapeo a 0.25× – 4× exp simétrico.
  // Inclinar a izq baja 2 octavas, a der sube 2 octavas. Centro = 1×.
  static uint32_t imu_last_ms = 0;
  if (imu_ok && now - imu_last_ms >= IMU_READ_MS) {
    imu_last_ms = now;
    int16_t ax, ay, az, gx, gy, gz;
    mpu.getMotion6(&ax, &ay, &az, &gx, &gy, &gz);
    float ax_norm = (float)ax * (1.0f / 16384.0f);
    if (ax_norm >  1.0f) ax_norm =  1.0f;
    if (ax_norm < -1.0f) ax_norm = -1.0f;
    float pitch_target = powf(2.0f, ax_norm * 2.0f);   // 0.25× – 4×
    global_pitch_smoothed += IMU_SMOOTH * (pitch_target - global_pitch_smoothed);
  }
  // El siren freq también sigue al pitch global (base 440 Hz × pitch_factor)
  osc.freq = 440.0f * global_pitch_smoothed;

  // ---- BTN1/2/3 → TRIGGER sample 1/2/3 (HOLD para sonar) ----
  for (int i = 0; i < 3; i++) {
    if (btnPressed(i)) {
      sp[i].playing = true;
      sp[i].phase   = 0.0;
      // Si BTN5 random tiene esta voz capturada, marcar restore=true
      // para que al soltar BTN5 la voz quede ON mientras este BTN siga hold.
      if (random_active && random_idx == i) random_restore = true;
      Serial.printf("S%d ON\n", i + 1);
      refreshTransport();
    }
    if (btnReleased(i)) {
      // Solo apagar si BTN5 random NO sostiene esta voz
      if (random_active && random_idx == i) {
        // BTN5 sigue hold sobre esta voz → no apagar, solo marcar el restore
        random_restore = false;
      } else {
        sp[i].playing = false;
        Serial.printf("S%d OFF\n", i + 1);
        refreshTransport();
      }
    }
  }

  // ---- BTN4 → TRIGGER siren (HOLD = sustain con gate, release = decay) ----
  if (btnPressed(3)) {
    sirenTrigger(osc.freq);
    osc.gate = true;
    Serial.printf("SIREN gate freq=%.0f Hz\n", osc.freq);
  }
  if (btnReleased(3)) {
    osc.gate = false;
    Serial.println("SIREN release");
  }

  // ---- BTN5 → RANDOM sample (HOLD) — elige uno de los 3 al apretar ----
  // Restaura el estado previo de esa voz al soltar (para no apagar lo que ya estaba).
  // random_idx / random_restore son globales (también usados por BTN1/2/3 sync).
  if (btnPressed(4)) {
    // elegir solo entre samples realmente cargados (len > 16 = no placeholder)
    int loaded[3]; int n = 0;
    for (int i = 0; i < 3; i++) if (SAMPLE_LENS[i] > 16) loaded[n++] = i;
    if (n > 0) {
      random_idx     = loaded[esp_random() % n];
      // restore basado en si el BTN del sample elegido está sostenido en este momento
      random_restore = btnHeld(random_idx);
      sp[random_idx].playing = true;
      sp[random_idx].phase   = 0.0;
      random_active = true;
      refreshTransport();
      Serial.printf("RANDOM sample %d (restore=%d)\n", random_idx + 1, random_restore);
    } else {
      Serial.println("RANDOM ignorado — no hay samples cargados");
    }
  }
  if (btnReleased(4)) {
    if (random_active) {
      sp[random_idx].playing = random_restore;
      random_active = false;
      refreshTransport();
      Serial.println("RANDOM release");
    }
  }

  // Heartbeat 2s
  static uint32_t hb_t = 0;
  if (now - hb_t > 2000) {
    hb_t = now;
    const char* tnames[] = {"STOP", "PLAY", "RANDOM"};
    Serial.printf("HB %s s1=%d s2=%d s3=%d pitch=%.2f dlyT=%.2f dlyFb=%.2f lfoR=%.2f lfoD=%.2f\n",
                  tnames[(int)transport],
                  sp[0].playing, sp[1].playing, sp[2].playing,
                  global_pitch_smoothed, dly.time, dly.feedback,
                  lfo.rate, lfo.depth);
  }

  // Consumir los flancos de los botones — DEBE ir después de todos los btnPressed/Released.
  buttonsClearEdges();

  // Render y output
  renderBlock();
  size_t written;
  i2s_channel_write(tx_chan, out_buf, sizeof(out_buf), &written, portMAX_DELAY);
}